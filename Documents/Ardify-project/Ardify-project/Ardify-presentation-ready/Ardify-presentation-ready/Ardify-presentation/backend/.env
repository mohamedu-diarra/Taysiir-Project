# MongoDB Atlas (FREE tier)
# 1. Go to https://cloud.mongodb.com
# 2. Create cluster → Connect → Drivers → Node.js
# 3. Paste your connection string below
MONGODB_URI=mongodb://localhost:27017/ardfiy

# JWT Secrets (generate random strings - keep secret!)
JWT_SECRET=ardify_super_secret_jwt_key_2024_presentation
JWT_REFRESH_SECRET=ardify_refresh_secret_jwt_key_2024_presentation

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

